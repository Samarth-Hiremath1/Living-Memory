    {
      "id": "obs-elena-sandhill-1",
      "stay_id": "stay-elena-sandhill-2026",
      "guest_id": "guest-elena-vasquez",
      "property_id": "sand-hill",
      "raw_text": "Ms. Vasquez requested a quiet desk setup in her suite as she has several London calls. Also asked for a proper tea service at 4pm.",
      "structured": {},
