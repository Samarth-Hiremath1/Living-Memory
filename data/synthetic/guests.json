      "guest_id": "guest-marcus-chen",
      "property_id": "sand-hill",
      "raw_text": "Mr. Chen asked about the poolside cabana availability for tomorrow. He mentioned he wants to spend the full day by the water.",
      "structured": {},
      "tags": ["poolside", "cabana", "relaxation"],
      "source": "staff_text",
