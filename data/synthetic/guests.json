  "observations": [
    {
      "id": "obs-anna-hk-1",
      "stay_id": "stay-anna-hk-2023",
      "guest_id": "guest-anna-lindqvist",
      "property_id": "hong-kong",
      "raw_text": "Guest asked about quiet breakfast spots away from the main dining room. Mentioned she prefers to start the day slowly and doesn't enjoy crowds in the morning. Recommended the harbour terrace at 7am.",
      "structured": {},
      "tags": ["breakfast", "quiet", "morning routine", "solitude"],
      "source": "staff_text",
      "timestamp": "2023-03-16T07:30:00",
      "sentiment": "positive"
    },
    {
      "id": "obs-anna-hk-2",
      "stay_id": "stay-anna-hk-2023",
      "guest_id": "guest-anna-lindqvist",
      "property_id": "hong-kong",
      "raw_text": "Ms. Lindqvist had dinner at the restaurant and spent an unusually long time with the sommelier. She was particularly interested in Austrian Grüner Veltliner and asked if we had any natural wine options. Also mentioned she's from Sweden originally but has lived in Tokyo for eight years.",
      "structured": {},
      "tags": ["wine", "austrian wine", "grüner veltliner", "natural wine", "tokyo", "swedish"],
      "source": "staff_text",
      "timestamp": "2023-03-17T22:00:00",
      "sentiment": "positive"
    },
    {
      "id": "obs-anna-carlyle-1",
      "stay_id": "stay-anna-carlyle-2023",
      "guest_id": "guest-anna-lindqvist",
      "property_id": "carlyle",
      "raw_text": "Guest arrived from an architecture conference and was visibly excited about a panel she attended on brutalist residential buildings. Asked if we had any architecture books in the library related to New York's mid-century period.",
      "structured": {},
      "tags": ["architecture", "brutalism", "mid-century", "conference", "books"],
      "source": "staff_text",
      "timestamp": "2023-09-20T18:00:00",
      "sentiment": "positive"
    },
    {
      "id": "obs-anna-carlyle-2",
      "stay_id": "stay-anna-carlyle-2023",
      "guest_id": "guest-anna-lindqvist",
      "property_id": "carlyle",
      "raw_text": "Ms. Lindqvist went for an early morning run in Central Park — came back at 6:45am looking energized. She mentioned she tries to run or walk somewhere green every morning when she travels. Said she misses Japanese forests. Took one of our park maps.",
      "structured": {},
      "tags": ["running", "morning", "nature", "central park", "japanese forests", "active"],
      "source": "staff_text",
      "timestamp": "2023-09-21T07:15:00",
      "sentiment": "positive"
    },
    {
      "id": "obs-anna-carlyle-3",
      "stay_id": "stay-anna-carlyle-2023",
      "guest_id": "guest-anna-lindqvist",
      "property_id": "carlyle",
      "raw_text": "Guest checked in with room temperature at 67°F — said she finds hotel rooms usually too warm. Specifically asked for it to stay there for the full stay. Room was set at 67°F throughout. No complaints.",
      "structured": {},
      "tags": ["room temperature", "67f", "cool room", "preference"],
      "source": "staff_text",
      "timestamp": "2023-09-20T16:00:00",
      "sentiment": "neutral"
    },
    {
      "id": "obs-marcus-hk-1",
      "stay_id": "stay-marcus-hk-2023",
      "guest_id": "guest-marcus-chen",
      "property_id": "hong-kong",
      "raw_text": "Mr. Chen had a detailed conversation with the concierge about Art Basel programming. He's a collector — specifically interested in Southeast Asian and East Asian contemporary. Mentioned he's been buying for about 12 years. Also ordered Côte de Nuits at dinner and spent time talking with the sommelier about specific producers.",
      "structured": {},
      "tags": ["art", "art basel", "collector", "contemporary art", "wine", "burgundy"],
      "source": "staff_text",
      "timestamp": "2023-05-21T21:00:00",
      "sentiment": "positive"
    },
    {
      "id": "obs-marcus-crillon-1",
      "stay_id": "stay-marcus-crillon-2024",
      "guest_id": "guest-marcus-chen",
      "property_id": "crillon",
      "raw_text": "Anniversary stay with wife Sophie. Mr. Chen arranged a private dinner in advance but mentioned he wanted the evening to feel spontaneous for her — asked us not to reference the reservation. Sophie is a landscape architect. They both ordered from the natural wine section and asked our sommelier to tell them the story of each bottle.",
      "structured": {},
      "tags": ["anniversary", "wife", "spontaneous", "natural wine", "landscape architect"],
      "source": "staff_text",
      "timestamp": "2024-10-01T20:00:00",
      "sentiment": "positive"
    },
    {
      "id": "obs-elena-crillon-1",
      "stay_id": "stay-elena-crillon-2023",
      "guest_id": "guest-elena-vasquez",
      "property_id": "crillon",
      "raw_text": "Ms. Vasquez asked the concierge for bookshop recommendations — specifically looking for a good French translation of a novel she mentioned (I didn't catch the title). She ended up at Galignani and came back with four books. Mentioned she runs a cultural foundation in Madrid focused on contemporary Spanish and Latin American art.",
      "structured": {},
      "tags": ["books", "bookshop", "reading", "madrid", "cultural foundation", "art"],
      "source": "staff_text",
      "timestamp": "2023-09-11T16:00:00",
      "sentiment": "positive"
    },
    {
      "id": "obs-elena-crillon-2",
      "stay_id": "stay-elena-crillon-2023",
      "guest_id": "guest-elena-vasquez",
      "property_id": "crillon",
      "raw_text": "Guest attended a private dinner at a gallery in Marais — she mentioned it was a curator she's known for years. Came back late and had a nightcap at Les Ambassadeurs bar. Seemed energized. Said Paris is the only city where she doesn't feel the need to sleep until the city does.",
      "structured": {},
      "tags": ["gallery", "art world", "paris night", "les ambassadeurs", "social energy"],
      "source": "staff_text",
      "timestamp": "2023-09-12T23:45:00",
      "sentiment": "positive"
    },
    {
      "id": "obs-elena-carlyle-1",
      "stay_id": "stay-elena-carlyle-2024",
      "guest_id": "guest-elena-vasquez",
      "property_id": "carlyle",
      "raw_text": "Ms. Vasquez is here for Frieze. She was buying for the foundation — mentioned she's looking at several works by Colombian and Mexican painters. Had a meeting at the hotel with a gallerist from Madrid who flew in. Very focused. Asked for a quiet table in a corner during both dinners.",
      "structured": {},
      "tags": ["frieze", "art fair", "buying", "colombia", "mexico", "gallerist", "quiet table"],
      "source": "staff_text",
      "timestamp": "2024-05-15T19:00:00",
      "sentiment": "neutral"
    },
    {
      "id": "obs-james-carlyle-1",
      "stay_id": "stay-james-carlyle-2024",
      "guest_id": "guest-james-okafor",
      "property_id": "carlyle",
      "raw_text": "First time at the Carlyle. Mr. Okafor asked immediately about Bemelmans Bar and whether Café Carlyle had any live jazz this week. He seemed genuinely knowledgeable — mentioned Coltrane and Monk unprompted in the same sentence. Later said he went to school in New York and hasn't been back in seven years.",
      "structured": {},
      "tags": ["jazz", "bemelmans", "café carlyle", "coltrane", "monk", "new york history", "first time"],
      "source": "staff_text",
      "timestamp": "2024-02-12T18:00:00",
      "sentiment": "positive"
    },
    {
      "id": "obs-yuki-fuschl-1",
      "stay_id": "stay-yuki-fuschl-2023",
      "guest_id": "guest-yuki-nakamura",
      "property_id": "schloss-fuschl",
      "raw_text": "Mr. Nakamura is an architect from Osaka. He spent the first morning photographing the castle's exterior details — specifically the stonework and joinery on the historic wing. Asked our historian for references on the original construction techniques. Very quiet guest. Clearly needs and enjoys solitude.",
      "structured": {},
      "tags": ["architecture", "photography", "stonework", "solitude", "historian", "quiet"],
      "source": "staff_text",
      "timestamp": "2023-06-02T10:00:00",
      "sentiment": "positive"
    },
    {
      "id": "obs-yuki-fuschl-2",
      "stay_id": "stay-yuki-fuschl-2023",
      "guest_id": "guest-yuki-nakamura",
      "property_id": "schloss-fuschl",
      "raw_text": "Guest asked about the alpine foraging walk — Gerald Aichriedler's tour. Went on the 6am mushroom walk and came back genuinely moved by it. Said it reminded him of childhood walks with his grandfather in the mountains near Nara. Left a handwritten thank-you note for Gerald.",
      "structured": {},
      "tags": ["foraging", "gerald", "placemaker", "mountains", "nara", "childhood memory", "thank you note"],
      "source": "staff_text",
      "timestamp": "2023-06-03T09:00:00",
      "sentiment": "positive"
    },
    {
      "id": "obs-yuki-crillon-1",
      "stay_id": "stay-yuki-crillon-2024",
      "guest_id": "guest-yuki-nakamura",
      "property_id": "crillon",
      "raw_text": "Mr. Nakamura specifically requested no television in the room. Also asked if there was a traditional Japanese breakfast option — we arranged an onigiri from a nearby Japanese grocer and a proper green tea setup. He was clearly delighted. Came back from the Pompidou retrospective and wanted to talk about the Tadao Ando exhibition.",
      "structured": {},
      "tags": ["no television", "japanese breakfast", "tadao ando", "pompidou", "green tea", "quiet"],
      "source": "staff_text",
